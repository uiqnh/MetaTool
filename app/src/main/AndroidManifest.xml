<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 이미지의 위치 메타데이터(EXIF GPS)에 접근하기 위한 권한 -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <!-- Android 12 이하에서 이미지 파일을 읽기 위한 권한 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13 이상에서 이미지 파일을 읽기 위한 권한 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Google Maps 지도 데이터를 불러오기 위한 인터넷 권한 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Google Maps 표시를 위한 OpenGL ES 2.0 사용 선언 -->
    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/metatool_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/metatool_icon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Project"
        tools:targetApi="31">
        <activity android:name=".AnalyzeActivity" />
        <activity android:name=".StatsActivity" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Google Maps API 키 -->
        <meta-data
            android:name="com.google.android.maps.v2.API_KEY"
            android:value="GOOGLE_MAPS_API_KEY" />
    </application>

</manifest>